' ============================================================
' UML DERIVED FROM THE ACTUAL SOURCE CODE
'   Generated from headers under Project1/Project1/*.h and
'   cross-checked against the corresponding .cpp files.
'   Wherever this conflicts with final_UML(usesProt).puml, the
'   code wins (the older UML is aspirational in places).
' ============================================================

title Metal Slug — Class Diagram (from current code)

top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam groupInheritance 2
skinparam nodesep 50
skinparam ranksep 80

' ============================================================
' VALUE / UTILITY TYPES
' ============================================================
class coordSyst <<struct>> {
    + x : float
    + y : float
}
class Box <<struct>> {
    + x : float
    + y : float
    + w : float
    + h : float
}
class Crater <<struct>> {
    + x : int
    + y : int
    + width : int
    + depth : int
    + exposureTime : float
}
class EnemySpawn <<struct>> {
    + masterCopy : Enemy*
    + spawnPosition : coordSyst
    + batchSize : int
    + biome : Biome*
}

