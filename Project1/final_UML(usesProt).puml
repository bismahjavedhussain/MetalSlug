' ============================================================
' ENTITY ROOT
' ============================================================
abstract class Entity {
    # position : coordSyst
    # velocity : coordSyst
    # width : float
    # height : float
    # isAlive : bool
    # isOnGround : bool
    # touchesWall : bool
    + virtual ~Entity() = default
    + {abstract} update(tm:TileMap&, dt:float) : void
    + {abstract} render(rw:sf::RenderWindow&) : void
    + checkCollision(other:Entity*) : bool
    + getHitbox() : Box
}

abstract class DamagableEntity {
    # healthPoints : int
    # maxHealthPoints : int
    # isInvulnerable : bool
    # currentDamageState : DamageState*
    + virtual takeDamage(amt:int, src:DamageSource*) : void
    + virtual die() : void
    + advanceDamageState() : void
    + getDamageState() : DamageState*
}

note right of DamagableEntity
  Damage staging is owned here as a swappable
  DamageState* (NormalDamageState -> InjuredDamageState
  -> CriticalDamageState -> DeadDamageState).
  Spec: "Same damage taking applies to player vehicles."
end note

