' EnemyVehicle: autonomous vehicles. Inherits Vehicle's HP / damage-state /
' render pipeline; its concrete subclasses (FlyingTara / M15ABradley /
' EnemySub) bake their own locomotion into update() rather than going
' through GroundVehicle / AerialVehicle / AquaticVehicle (whose helpers
' are pilot-input-only).
abstract class EnemyVehicle {
    # movesHorizontally : bool
    # scoreValue : int
    + virtual onDestroy() : void
    + die() : void
    + getScoreValue() : int
}
