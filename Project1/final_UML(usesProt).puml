}

' ============================================================
' ENEMY BRANCH
' ============================================================
abstract class Enemy {
    # scoreValue : int
    # isGrudgeful : bool
    # currentAIState : EnemyAIState*
    # pendingDrop : Collectible*
    + {abstract} attack() : void
    + virtual update(tm:TileMap&, dt:float) : void
    + virtual render(rw:sf::RenderWindow&) : void
    + virtual onDeath() : void
    + die() : void
    + virtual onPlayerContact(p:PlayerSoldier*) : void
    + virtual blocksProjectile(incomingDir:coordSyst, isExplosive:bool) : bool
    + virtual isAerial() : bool
    + pathToPlayer(tm:TileMap&, target:coordSyst) : void
    + changeAIState(s:EnemyAIState*) : void
    + {abstract} clone() : Enemy*
    + getScoreValue() : int
    + getIsGrudgeful() : bool
    + takePendingDrop() : Collectible*
}

note right of Enemy
  Polymorphic dispatch entry-points lifted to Enemy
  (onPlayerContact, blocksProjectile, isAerial) so
  CollisionManager / ScoreManager dispatch through
  Enemy* without dynamic_cast (P1 invariant).
  Default behaviours are inert; subclasses override
  only what they customise.
end note

