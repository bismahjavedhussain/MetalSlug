' ============================================================
' DAMAGE STATE (replaces enum DamageState) — State Pattern
' ============================================================
abstract class DamageState {
    # owner : DamagableEntity*
    # remainingTime : float
    + virtual ~DamageState() = default
    + {abstract} enter(d:DamagableEntity*) : void
    + {abstract} exit(d:DamagableEntity*) : void
    + {abstract} update(d:DamagableEntity*, dt:float) : void
    + {abstract} hueAlpha() : float
    + {abstract} next() : DamageState*
}
class NormalDamageState {
    + enter(d:DamagableEntity*) : void
    + exit(d:DamagableEntity*) : void
    + update(d:DamagableEntity*, dt:float) : void
    + hueAlpha() : float
    + next() : DamageState*
}
class InjuredDamageState {
    + enter(d:DamagableEntity*) : void
    + exit(d:DamagableEntity*) : void
    + update(d:DamagableEntity*, dt:float) : void
    + hueAlpha() : float
    + next() : DamageState*
}
class CriticalDamageState {
    + enter(d:DamagableEntity*) : void
    + exit(d:DamagableEntity*) : void
