@startuml MetalSlug_Final_Merged

' ============================================================
' FINAL MERGED UML — NO ENUMS
'   - TA.puml structure is the LOCKED foundation
'   - corrected_UML(shanu).puml content merged on top
'   - Validated against OOPSP26Project.md
'   - No std::string / std::vector / STL — char arrays + raw ptrs
'   - SFML usage limited to allowedSFML.md whitelist
'   - Every former enum is replaced by a polymorphic class hierarchy
'     (State / Strategy / Command / Factory / Prototype patterns)
' ============================================================

title OOP_26 Metal Slug — Final UML

top to bottom direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontStyle bold
skinparam groupInheritance 2
skinparam nodesep 50
skinparam ranksep 80

' ============================================================
' UTILITY STRUCTS
' ============================================================
class coordSyst <<struct>> {
    + x : float
    + y : float
}
class Box <<struct>> {
    + x : float
    + y : float
    + w : float
    + h : float
}
class Crater <<struct>> {
    + x : int
    + y : int
    + width : int
    + depth : int
    + exposureTime : float
}
class FingerprintParam <<struct>> {
    + id : char[16]
    + category : char[32]
    + name : char[64]
    + value : float
    + weight : float
    + minVal : float
    + maxVal : float
    + unit : char[16]
    + dataType : char[16]
    + description : char[128]
}
class RunRecord <<struct>> {
    + midpointScore : int
    + finalScore : int
    + timestamp : int
}
class Snapshot <<struct>> {
    + entityStates : char*
    + dataSize : int
    + timestamp : float
    + score : int
}
class TimelineNode <<struct>> {
    + snapshot : Snapshot*
    + parent : TimelineNode*
