}

' ============================================================
' TILE (replaces enum TileType) — Polymorphic block
' ============================================================
abstract class Tile {
    # gridX : int
    # gridY : int
    + virtual ~Tile() = default
    + {abstract} isSolid() : bool
    + {abstract} isDestructible() : bool
    + {abstract} isWater() : bool
    + virtual onEntityEnter(e:Entity*) : void
    + virtual onExplosion(blastRadius:float) : void
}
class AirTile {
